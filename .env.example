# Application
APP_NAME="Children's Literacy Learning Platform"
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL required, SQLite not acceptable)
DATABASE_URL=postgresql+asyncpg://literacy_user:literacy_pass@localhost:5432/literacy_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Security — change these in production!
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES=15
JWT_REFRESH_TOKEN_EXPIRES=7
JWT_ALGORITHM=HS256

# Password hashing
BCRYPT_ROUNDS=12

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
